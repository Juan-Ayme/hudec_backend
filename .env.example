# =============================================================================
# KAWII / Consorcio HUDEC — plantilla de configuración
# =============================================================================
# Copiar a `.env` y rellenar. NO commitear `.env` (con datos reales).
#
# En el modelo multi-tenant, este .env NO contiene datos de empresa alguna.
# Todos los datos por empresa (token BSale, IDs operativos, umbrales, marca,
# exclusiones, metas) viven en las tablas `app_config` y `companies` de la DB,
# editables desde la UI /configuracion.
# =============================================================================

# ---- App ----
APP_NAME="KAWII API"
APP_VERSION=1.0.0
TIMEZONE=America/Lima
DEBUG=false

# ---- Base de datos ----
# IMPORTANTE: DB_USER debe ser un rol NOSUPERUSER NOBYPASSRLS (`hudec_app`).
# Un superuser bypassaría Row-Level Security y rompería el aislamiento.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kawii_mt
DB_USER=hudec_app
DB_PASSWORD=CAMBIAR

# ---- Auth (JWT en cookie httpOnly) ----
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CAMBIAR
JWT_EXPIRES_DAYS=7

# COOKIE_SECURE=true cuando corre por HTTPS (producción). Dev local con HTTP → false.
COOKIE_SECURE=false
# lax por default. Backend + frontend en dominios distintos → "none" + COOKIE_SECURE=true.
COOKIE_SAMESITE=lax

# ---- Cifrado de tokens BSale (companies.bsale_token) ----
# CRÍTICO: sin esta clave, los tokens en DB quedan ilegibles.
# Backup obligatorio en password manager (1Password, Bitwarden, etc.).
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
TOKEN_ENCRYPTION_KEY=CAMBIAR

# ---- Admin bootstrap (solo la primera vez, si app_users está vacía) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_INMEDIATAMENTE

# ---- CORS ----
# En prod, restringir al dominio del frontend.
# Ejemplo: CORS_ORIGINS=["https://hudec-frontend.onrender.com"]
CORS_ORIGINS=["*"]
